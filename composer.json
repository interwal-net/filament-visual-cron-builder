{
    "name": "interwal-net/filament-visual-cron-builder",
    "description": "A reusable Filament v4/v5 form field that builds cron expressions visually with native selects - no JS bundle.",
    "keywords": [
        "filament",
        "filamentphp",
        "laravel",
        "cron",
        "scheduler",
        "form-field"
    ],
    "homepage": "https://github.com/interwal-net/filament-visual-cron-builder",
    "license": "MIT",
    "authors": [
        {
            "name": "Robert Walaski",
            "email": "robert@walaski.cz",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "dragonmantank/cron-expression": "^3.3",
        "filament/forms": "^4.0 || ^5.0",
        "illuminate/contracts": "^12.0 || ^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "filament/filament": "^4.0 || ^5.0",
        "larastan/larastan": "^3.10",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "InterwalNet\\CronBuilder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "InterwalNet\\CronBuilder\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "InterwalNet\\CronBuilder\\CronBuilderServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": "@prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "demo:db": "@php vendor/bin/testbench migrate:fresh --seed --seeder=\"Workbench\\Database\\Seeders\\DatabaseSeeder\" --force --ansi",
        "serve": [
            "@build",
            "@demo:db",
            "@php vendor/bin/testbench serve"
        ],
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
